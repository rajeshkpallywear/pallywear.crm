rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email in ['rajeshkpallywear@gmail.com', 'ceo@pallywear.com', 'daniel.smpallywear@gmail.com'] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function hasUserRole(roles) {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserRole() in roles;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\\\-]+$');
    }

    // Users Collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['id', 'email', 'role', 'name', 'createdAt']) &&
               data.id is string &&
               data.email is string &&
               data.role in ['admin', 'staff', 'accounts', 'order_management', 'production', 'delivery', 'marketing', 'user'] &&
               data.name is string &&
               data.createdAt is string;
      }

      function isAdminRoleEligible(email) {
        return email == 'ceo@pallywear.com' || 
               email == 'rajeshkpallywear@gmail.com' || 
               email == 'daniel.smpallywear@gmail.com' ||
               email.matches('(?i)^admin.*') || 
               email.matches('(?i)^ceo.*');
      }

      function isStaff() {
        return isSignedIn() && (
          hasUserRole(['staff', 'admin']) ||
          isAdmin() ||
          request.auth.token.email.matches('(?i)^staff.*')
        );
      }

      allow get: if isOwner(userId) || isAdmin() || isStaff();
      allow list: if isSignedIn() && (isAdmin() || isStaff());
      
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                      (isAdminRoleEligible(request.resource.data.email) ? request.resource.data.role == 'admin' : true);
      
      allow update: if isOwner(userId) && 
                      (
                        // Allow own field updates except role usually
                        (request.resource.data.role == resource.data.role && request.resource.data.email == resource.data.email) ||
                        isAdmin()
                      );
      
      allow delete: if isAdmin();
    }

    // Test Connection
    match /test/connection {
      allow read: if true;
    }

    // Leads Collection
    match /leads/{leadId} {
      function isValidLead(data) {
        return data.keys().hasAll(['id', 'name', 'leadType', 'createdBy', 'entryDate']) &&
               data.id is string &&
               data.name is string &&
               data.leadType in ['Hot', 'Warm', 'Cold'] &&
               data.createdBy == request.auth.uid;
      }

      allow get, list: if isSignedIn() && (resource.data.createdBy == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && isValidId(leadId) && (request.resource.data.createdBy == request.auth.uid) && isValidLead(request.resource.data);
      
      allow update: if isSignedIn() && (resource.data.createdBy == request.auth.uid || isAdmin()) && 
                      isValidLead(request.resource.data) &&
                      request.resource.data.createdBy == resource.data.createdBy;
                      
      allow delete: if isSignedIn() && (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    // Invoices Collection
    match /invoices/{invoiceId} {
      function isValidInvoice(data) {
        return data.keys().hasAll(['id', 'invoiceNumber', 'total', 'createdBy', 'createdAt']) &&
               data.id is string &&
               data.invoiceNumber is string &&
               data.total is number &&
               data.createdBy is string &&
               data.createdAt is string &&
               data.createdBy == request.auth.uid;
      }

      allow get, list: if isSignedIn() && (resource.data.createdBy == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && (request.resource.data.id == invoiceId) && isValidInvoice(request.resource.data);
      allow update: if isSignedIn() && (resource.data.createdBy == request.auth.uid || isAdmin()) && 
                      isValidInvoice(request.resource.data) &&
                      request.resource.data.createdBy == resource.data.createdBy;
      allow delete: if isSignedIn() && (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    // Orders Collection
    match /orders/{orderId} {
      function isValidOrder(data) {
        return data.keys().hasAll(['id', 'status', 'createdBy', 'createdAt']) &&
               data.id is string &&
               data.status is string &&
               data.createdBy is string;
      }

      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(orderId) && isValidOrder(request.resource.data) && request.resource.data.createdBy == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    // App Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Inventory Collection
    match /inventory/{itemId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        hasUserRole(['admin', 'order_management', 'staff', 'production'])
      );
      allow write: if isSignedIn() && (
        isAdmin() ||
        hasUserRole(['admin', 'order_management'])
      );
    }
  }
}
