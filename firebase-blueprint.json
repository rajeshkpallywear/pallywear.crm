{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information and role.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "name": { "type": "string" },
        "avatar": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role", "name", "createdAt"]
    },
    "Lead": {
      "title": "Lead",
      "description": "Sales lead or client information.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "status": { "type": "string" },
        "leadType": { "type": "string" },
        "priority": { "type": "string" },
        "forecastedValue": { "type": "number" },
        "convertedValue": { "type": "number" },
        "totalOrderValue": { "type": "number" },
        "companyName": { "type": "string" },
        "source": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["id", "name", "status", "createdBy", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Authenticated user profiles."
    },
    "leads/{leadId}": {
      "schema": "Lead",
      "description": "Lead and client records."
    }
  }
}
