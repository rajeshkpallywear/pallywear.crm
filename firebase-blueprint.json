{
  "entities": {
    "AppSettings": {
      "title": "App Settings",
      "description": "Global application configuration.",
      "type": "object",
      "properties": {
        "adminOnlyRegistration": {
          "type": "boolean"
        }
      }
    },
    "User": {
      "title": "User",
      "description": "User profile information and role.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": [
            "user",
            "admin"
          ]
        },
        "name": {
          "type": "string"
        },
        "avatar": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "email",
        "role",
        "name",
        "createdAt"
      ]
    },
    "Lead": {
      "title": "Lead",
      "description": "Sales lead or client information.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "leadType": {
          "type": "string"
        },
        "priority": {
          "type": "string"
        },
        "forecastedValue": {
          "type": "number"
        },
        "convertedValue": {
          "type": "number"
        },
        "totalOrderValue": {
          "type": "number"
        },
        "discountCode": {
          "type": "string"
        },
        "discountAmount": {
          "type": "number"
        },
        "netTotal": {
          "type": "number"
        },
        "companyName": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "createdBy": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "name",
        "status",
        "createdBy",
        "createdAt"
      ]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Invoice record for a lead or client.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "invoiceNumber": {
          "type": "string"
        },
        "date": {
          "type": "string"
        },
        "dueDate": {
          "type": "string"
        },
        "fromName": {
          "type": "string"
        },
        "fromEmail": {
          "type": "string"
        },
        "fromAddress": {
          "type": "string"
        },
        "billToName": {
          "type": "string"
        },
        "billToEmail": {
          "type": "string"
        },
        "billToAddress": {
          "type": "string"
        },
        "total": {
          "type": "number"
        },
        "status": {
          "type": "string"
        },
        "paymentMethod": {
          "type": "string",
          "enum": [
            "GPay",
            "PhonePay",
            "Cash",
            "Account",
            "UPI"
          ]
        },
        "productType": {
          "type": "string"
        },
        "productSubCategory": {
          "type": "string"
        },
        "customerPhoneNumber": {
          "type": "string"
        },
        "leadId": {
          "type": "string"
        },
        "createdBy": {
          "type": "string"
        },
        "createdByName": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "bankIfscCode": {
          "type": "string"
        },
        "bankAccountNumber": {
          "type": "string"
        },
        "companySignature": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "invoiceNumber",
        "total",
        "leadId",
        "createdBy",
        "createdAt"
      ]
    },
    "Order": {
      "title": "Order",
      "description": "Manufacturing or sales order record.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "customerInfo": {
          "type": "object"
        },
        "category": {
          "type": "string"
        },
        "quantity": {
          "type": "number"
        },
        "status": {
          "type": "string"
        },
        "createdBy": {
          "type": "string"
        },
        "createdAt": {
          "type": "number"
        },
        "updatedAt": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "status",
        "createdBy",
        "createdAt"
      ]
    },
    "InventoryMovement": {
      "title": "Inventory Movement",
      "description": "Record of stock inward or outward.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "inward",
            "outward"
          ]
        },
        "product": {
          "type": "string"
        },
        "productType": {
          "type": "string"
        },
        "quantity": {
          "type": "number"
        },
        "date": {
          "type": "string"
        },
        "createdAt": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "type",
        "product",
        "quantity",
        "date"
      ]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Authenticated user profiles."
    },
    "leads/{leadId}": {
      "schema": "Lead",
      "description": "Lead and client records."
    },
    "invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Invoice records."
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Order records for tracking production and delivery."
    },
    "inventory/{itemId}": {
      "schema": "InventoryMovement",
      "description": "Inventory stock movements."
    },
    "settings/{settingId}": {
      "schema": "AppSettings",
      "description": "Global application configuration settings."
    }
  }
}