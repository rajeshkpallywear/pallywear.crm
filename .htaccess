<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Route API requests to the PHP proxy inside the root api/ folder
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_URI} ^/api/(.*)$
  RewriteRule ^api/(.*)$ api/proxy.php?route=$1 [QSA,L]

  # Route all other traffic to the compiled dist folder
  RewriteCond %{REQUEST_URI} !^/dist/
  RewriteRule ^(.*)$ dist/$1 [L]
</IfModule>
